{
  "version": "1.0",
  "name": "ides_of_march",
  "stages": [
    {
      "name": "ides_data_integrity",
      "job": "update",
      "depends_on": [],
      "command": "py -3 -m ides_of_march.cli audit --strict --hours-ahead 48",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "game_datetime_utc"]},
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id", "game_datetime_utc"]},
        {"path": "data/market_lines_latest_by_game.csv", "min_rows": 0, "required_columns": ["event_id", "spread_line", "total_line"], "allow_empty_when_no_games": true}
      ],
      "produces": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id"]}
      ]
    },
    {
      "name": "ides_predict",
      "job": "update",
      "depends_on": ["ides_data_integrity"],
      "command": "py -3 -m ides_of_march.cli predict --mc-mode confidence_filter --hours-ahead 48",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "game_datetime_utc"]},
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]},
        {"path": "data/market_lines_latest_by_game.csv", "min_rows": 0, "required_columns": ["event_id", "spread_line", "total_line"], "allow_empty_when_no_games": true}
      ],
      "produces": [
        {"path": "data/ides_of_march/predictions_latest.csv", "min_rows": 0, "required_columns": ["game_id", "event_id", "projected_spread", "market_spread"], "allow_empty_when_no_games": true},
        {"path": "data/ides_of_march/bet_recs.csv", "min_rows": 0, "required_columns": ["game_id", "event_id", "bet_recommendation"], "allow_empty_when_no_games": true},
        {"path": "data/ides_of_march/agreement_bucket_report.csv", "min_rows": 1, "required_columns": ["agreement_bucket", "sample_size"]},
        {"path": "data/ides_of_march/situational_rulebook.csv", "min_rows": 1, "required_columns": ["rule_id", "sample_size", "accepted"]},
        {"path": "data/ides_of_march/run_manifest.json", "min_rows": 0}
      ]
    },
    {
      "name": "ides_backtest",
      "job": "rankings",
      "depends_on": [],
      "command": "py -3 -m ides_of_march.cli backtest",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "game_datetime_utc"]},
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]},
        {"path": "data/market_lines_latest_by_game.csv", "min_rows": 0, "required_columns": ["event_id", "spread_line", "total_line"], "allow_empty_when_no_games": true}
      ],
      "produces": [
        {"path": "data/ides_of_march/backtest_variant_scorecard.csv", "min_rows": 1, "required_columns": ["variant_id", "sample_size", "spread_mae", "winner_accuracy", "ats_accuracy"]},
        {"path": "data/ides_of_march/situational_rulebook.csv", "min_rows": 1, "required_columns": ["rule_id", "sample_size", "accepted"]},
        {"path": "data/ides_of_march/run_manifest.json", "min_rows": 0}
      ]
    }
  ]
}
