{
  "version": "1.0",
  "name": "ides_of_march",
  "stages": [
    {
      "name": "ides_data_integrity",
      "job": "update",
      "depends_on": [],
      "command": "python -m ides_of_march.cli audit --strict --hours-ahead 48 --hours-back 1",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "game_datetime_utc"]},
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id", "game_datetime_utc"]},
        {"path": "data/market_lines_latest_by_game.csv", "min_rows": 0, "required_columns": ["event_id", "spread_line", "total_line"], "allow_empty_when_no_games": true}
      ],
      "produces": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id"]}
      ]
    },
    {
      "name": "ides_predict",
      "job": "update",
      "depends_on": ["ides_data_integrity"],
      "command": "python -m ides_of_march.cli predict --mc-mode confidence_filter --hours-ahead 48 --hours-back 1",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "game_datetime_utc"]},
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]},
        {"path": "data/market_lines_latest_by_game.csv", "min_rows": 0, "required_columns": ["event_id", "spread_line", "total_line"], "allow_empty_when_no_games": true}
      ],
      "produces": [
        {"path": "data/reports/game_predictions_master.csv", "min_rows": 0, "required_columns": ["run_id", "game_id", "model_spread_team_a", "market_spread_team_a"], "allow_empty_when_no_games": true},
        {"path": "data/actionable/bet_recommendations.csv", "min_rows": 0, "required_columns": ["run_id", "game_id", "bet_type"], "allow_empty_when_no_games": true, "allow_empty_when_no_market_lines": true},
        {"path": "data/actionable/watchlist_games.csv", "min_rows": 0, "required_columns": ["run_id", "game_id", "watchlist_reason"], "allow_empty_when_no_games": true, "allow_empty": true},
        {"path": "data/actionable/no_bet_explanations.csv", "min_rows": 0, "required_columns": ["run_id", "game_id", "no_bet_reason"], "allow_empty_when_no_games": true},
        {"path": "data/actionable/daily_card_summary.csv", "min_rows": 0, "required_columns": ["run_id", "games_on_card"], "allow_empty_when_no_games": true},
        {"path": "data/reports/agreement_analysis_results.csv", "min_rows": 1, "required_columns": ["run_id", "agreement_bucket", "sample_size"]},
        {"path": "data/logs/run_manifest.json", "min_rows": 0}
      ]
    },
    {
      "name": "ides_backtest",
      "job": "rankings",
      "depends_on": [],
      "command": "python -m ides_of_march.cli backtest",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "game_datetime_utc"]},
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]},
        {"path": "data/market_lines_latest_by_game.csv", "min_rows": 0, "required_columns": ["event_id", "spread_line", "total_line"], "allow_empty_when_no_games": true}
      ],
      "produces": [
        {"path": "data/reports/backtest_model_summary.csv", "min_rows": 1, "required_columns": ["run_id", "variant_name", "spread_mae", "winner_accuracy", "ats_win_pct_all"]},
        {"path": "data/logs/run_manifest.json", "min_rows": 0}
      ]
    }
  ]
}
