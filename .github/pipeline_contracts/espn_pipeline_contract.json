{
  "version": "1.0",
  "name": "update_espn_cbb",
  "stages": [
    {
      "name": "espn_pipeline",
      "job": "update",
      "depends_on": [],
      "command": "python espn_pipeline.py --days-back {days_back}",
      "requires": [],
      "produces": [
        {
          "path": "data/games.csv",
          "min_rows": 1,
          "required_columns": ["game_id", "game_datetime_utc"]
        },
        {
          "path": "data/team_game_weighted.csv",
          "min_rows": 1,
          "required_columns": ["event_id", "team_id", "game_datetime_utc"]
        },
        {
          "path": "data/team_pretournament_snapshot.csv",
          "min_rows": 1,
          "required_columns": ["team_id"]
        }
      ]
    },
    {
      "name": "espn_pipeline_boxscore_only",
      "job": "update",
      "depends_on": [],
      "command": "python espn_pipeline.py --days-back {days_back} --summary-mode team-only --no-build-derived-features --strip-market-lines",
      "requires": [],
      "produces": [
        {
          "path": "data/games.csv",
          "min_rows": 1,
          "required_columns": ["game_id", "game_datetime_utc", "date", "home_wins", "home_losses", "away_wins", "away_losses"]
        },
        {
          "path": "data/team_game_logs.csv",
          "min_rows": 1,
          "required_columns": ["event_id", "team_id", "wins", "losses", "fgm", "fga", "ftm", "fta", "tpm", "tpa", "orb", "drb", "reb", "tov", "ast"]
        }
      ]
    },
    {
      "name": "rotation_features",
      "job": "update",
      "depends_on": ["espn_pipeline"],
      "command": "python cbb_rotation_features.py",
      "requires": [
        {"path": "data/player_game_logs.csv", "min_rows": 1},
        {"path": "data/player_game_metrics.csv", "min_rows": 1}
      ],
      "produces": [
        {"path": "data/rotation_features.csv", "min_rows": 1, "required_columns": ["game_id", "team_id"]}
      ]
    },
    {
      "name": "market_builder",
      "job": "update",
      "depends_on": ["espn_pipeline"],
      "command": "python -m pipeline.market_canonical --data-dir data --debug-dir debug",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "game_datetime_utc"]}
      ],
      "produces": [
        {
          "path": "data/market_lines_canonical.csv",
          "min_rows": 0,
          "required_columns": ["event_id", "spread_line", "total_line", "source"],
          "allow_empty_when_no_games": true
        },
        {
          "path": "data/market_lines_latest_by_game.csv",
          "min_rows": 0,
          "required_columns": ["event_id", "spread_line", "total_line", "line_source_used"],
          "allow_empty_when_no_games": true
        }
      ]
    },
    {
      "name": "situational_features",
      "job": "update",
      "depends_on": ["espn_pipeline"],
      "command": "python cbb_situational_features.py",
      "requires": [
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]}
      ],
      "produces": [
        {"path": "data/situational_features.csv", "min_rows": 1}
      ]
    },
    {
      "name": "luck_regression_features",
      "job": "update",
      "depends_on": ["espn_pipeline"],
      "command": "python cbb_luck_regression_features.py",
      "requires": [
        {"path": "data/team_game_weighted.csv", "min_rows": 1}
      ],
      "produces": [
        {"path": "data/luck_regression_features.csv", "min_rows": 1}
      ]
    },
    {
      "name": "advanced_metrics_builder",
      "job": "update",
      "depends_on": ["espn_pipeline", "rotation_features", "situational_features"],
      "command": "python -m pipeline.advanced_metrics.build_advanced_metrics",
      "requires": [
        {"path": "data/team_game_metrics.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]}
      ],
      "produces": [
        {
          "path": "data/advanced_metrics.csv",
          "min_rows": 0,
          "required_columns": ["event_id", "team_id"],
          "allow_empty_when_no_games": true
        }
      ]
    },
    {
      "name": "joint_models_predictions",
      "job": "update",
      "depends_on": ["espn_pipeline", "advanced_metrics_builder", "market_builder"],
      "command": "python -m model_lab.joint_models",
      "requires": [
        {"path": "data/games.csv", "min_rows": 1, "required_columns": ["game_id", "home_team_id", "away_team_id"]},
        {"path": "data/team_game_weighted.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]},
        {"path": "data/advanced_metrics.csv", "min_rows": 1, "required_columns": ["event_id", "team_id"]},
        {"path": "data/market_lines_latest_by_game.csv", "min_rows": 0, "required_columns": ["event_id", "spread_line", "total_line"], "allow_empty_when_no_games": true}
      ],
      "produces": [
        {
          "path": "data/team_snapshot.csv",
          "min_rows": 1,
          "required_columns": ["team_id"]
        },
        {
          "path": "data/predictions_joint_latest.csv",
          "min_rows": 0,
          "required_columns": ["game_id", "pred_total", "pred_margin"],
          "allow_empty_when_no_games": true
        },
        {
          "path": "data/predictions_joint_snapshots.csv",
          "min_rows": 0,
          "required_columns": ["game_id", "generated_at_utc"],
          "allow_empty_when_no_games": true
        }
      ]
    },
    {
      "name": "player_availability_features",
      "job": "update",
      "depends_on": ["espn_pipeline"],
      "command": "python player_availability_features.py",
      "requires": [
        {"path": "data/player_game_logs.csv", "min_rows": 1}
      ],
      "produces": [
        {"path": "data/player_availability_features.csv", "min_rows": 1}
      ]
    },
    {
      "name": "season_summaries",
      "job": "update",
      "depends_on": ["espn_pipeline"],
      "command": "python cbb_season_summaries.py",
      "requires": [
        {"path": "data/team_game_weighted.csv", "min_rows": 1}
      ],
      "produces": [
        {"path": "data/player_season_summary.csv", "min_rows": 1},
        {"path": "data/team_season_summary.csv", "min_rows": 1}
      ]
    },
    {
      "name": "rankings",
      "job": "rankings",
      "depends_on": [],
      "command": "python espn_rankings.py --top 25",
      "requires": [
        {
          "path": "data/team_game_weighted.csv",
          "min_rows": 1,
          "required_columns": ["team_id", "event_id", "game_datetime_utc"],
          "max_age_hours": 36
        },
        {
          "path": "data/team_pretournament_snapshot.csv",
          "min_rows": 1,
          "required_columns": ["team_id"],
          "max_age_hours": 36
        }
      ],
      "produces": [
        {"path": "data/cbb_rankings.csv", "min_rows": 1, "required_columns": ["team_id", "rank"]},
        {"path": "data/cbb_rankings_by_conference.csv", "min_rows": 1}
      ]
    }
  ]
}
